rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función para verificar si el usuario es un administrador
    // Comprueba si el UID del usuario que hace la petición existe como un documento en la colección 'admins'.
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // --- REGLA AÑADIDA ---
    // Reglas para la colección de administradores.
    // Permite que cualquier usuario autenticado lea la lista de admins para verificar permisos en el cliente.
    // La escritura está restringida para que solo se pueda gestionar desde un entorno de confianza (backend o consola).
    match /admins/{userId} {
      allow read: if request.auth != null;
      allow write: if false; // Previene la escritura desde el cliente
    }

    // Reglas para la colección 'catalog'
    match /catalog/{categoryId} {
      allow read: if true;
      allow write: if isAdmin(); // Solo los admins pueden crear, actualizar o borrar productos.
    }
    
    // Reglas para la colección de consejos de la comunidad
    match /community-tips/{tipId} {
      allow read: if resource.data.isApproved == true || isAdmin();
      allow create: if true; // Cualquiera puede enviar un consejo para moderación
      allow update: if request.auth != null || isAdmin(); // Usuarios logueados pueden añadir respuestas, admins pueden modificar
      allow delete: if isAdmin(); // Solo los admins pueden borrar el consejo principal y sus respuestas
    }
  }
}
