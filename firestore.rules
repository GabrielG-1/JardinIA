
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Regla explícita para la colección 'admins'
    match /admins/{uid} {
      // Un usuario autenticado solo puede leer su propio documento de admin.
      // Esto permite al cliente verificar el rol sin exponer toda la lista de admins.
      // Nadie puede escribir en esta colección desde el cliente.
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false; 
    }
    
    // Función helper para verificar si el usuario es un administrador.
    // Es más seguro y eficiente que leer una lista.
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Reglas para la colección 'catalog'
    match /catalog/{categoryId} {
      allow read: if true;
      // Solo los admins pueden crear, actualizar o borrar productos.
      allow write: if isAdmin(); 
    }
    
    // Reglas para la colección de consejos de la comunidad
    match /community-tips/{tipId} {
      allow read: if resource.data.isApproved == true || isAdmin();
      // Cualquiera puede enviar un consejo para moderación (si está autenticado)
      allow create: if request.auth != null; 
      // Usuarios logueados pueden añadir respuestas, admins pueden modificar todo
      allow update: if request.auth != null || isAdmin(); 
      // Solo los admins pueden borrar el consejo principal
      allow delete: if isAdmin();
    }
  }
}
