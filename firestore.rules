
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // El catálogo de productos debe ser de lectura pública
    // Se permite la actualización para poder cambiar las imágenes de los productos
    match /catalog/{categoryId} {
      allow read: if true;
      allow update: if true; 
    }

    // Los consejos de la comunidad pueden ser leídos por todos,
    // y cualquiera puede crear nuevos consejos o añadir respuestas (actualizar)
    match /community-tips/{tipId} {
      allow read, create, update: if true;
    }

    // La configuración del Hero debe ser de lectura pública para mostrar la imagen
    match /settings/hero {
      allow read: if true;
      allow update: if true;
    }

    // Por defecto, denegar el acceso a cualquier otra colección no especificada
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
