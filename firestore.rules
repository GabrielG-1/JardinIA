rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Reglas para la colección 'community-tips'
    match /community-tips/{tipId} {
      
      // Lectura: Cualquiera puede leer los consejos aprobados.
      allow read: if resource.data.isApproved == true;
      
      // Creación: Cualquiera puede enviar un nuevo consejo (que será moderado).
      allow create: if true;
      
      // Actualización (para añadir/eliminar respuestas): Solo administradores.
      allow update: if request.auth.token.admin == true;
      
      // Borrado: Solo administradores.
      allow delete: if request.auth.token.admin == true;
    }

    // Reglas para la colección 'catalog'
    match /catalog/{categoryId} {
      // Cualquiera puede leer el catálogo.
      allow read: if true;
      
      // Modificaciones (create, update, delete) solo para administradores.
      // Esta regla es un marcador de posición. Para una app en producción,
      // se necesitaría una lógica de administrador similar a la de 'community-tips'.
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
  }
}
