rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Reglas para la colección 'catalog'
    // Los administradores tienen control total (crear, editar, eliminar).
    // Cualquier usuario puede leer los productos.
    match /catalog/{categoryId} {
      allow read: if true;
      allow write: if request.auth.token.admin == true;
    }
    
    // Reglas para la colección de consejos de la comunidad
    match /community-tips/{tipId} {
      // Leer: Cualquiera puede leer si está aprobado. Los administradores pueden leer todo.
      allow read: if resource.data.isApproved == true || request.auth.token.admin == true;
      // Crear: Cualquiera puede enviar un consejo para moderación.
      allow create: if true;
      // Actualizar: Cualquiera que haya iniciado sesión puede añadir respuestas. Los admins pueden modificar todo.
      allow update: if request.auth != null;
      // Eliminar: Solo los administradores pueden borrar el consejo principal y las respuestas.
      allow delete: if request.auth.token.admin == true;
    }
  }
}
