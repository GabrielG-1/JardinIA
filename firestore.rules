
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      let adminEmails = firestore.get(/configuration/admin).data.emails;
      return request.auth != null && request.auth.token.email in adminEmails;
    }

    match /catalog/{docId} {
      allow read: if true;
      // Write operations (create, update, delete) are disallowed from the client.
      // They should only be performed by a trusted backend environment (e.g., using the Admin SDK).
      // For this app, product management is handled via the admin panel which should
      // ideally trigger secure backend functions.
      allow write: if isAdmin();
    }

    match /community-tips/{tipId} {
      allow read, create: if true;
      // Only authenticated admins can update or delete tips.
      allow update, delete: if isAdmin();
    }

    // This is a new document to store configuration that security rules can access.
    match /configuration/admin {
       allow read: if true;
       allow write: if false; // Should only be updated manually or via a secure script.
    }
  }
}
