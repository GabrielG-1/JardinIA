
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      // Un administrador es un usuario autenticado cuyo UID existe en la colección de 'admins'.
      return request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Reglas para la colección 'catalog'
    match /catalog/{categoryId} {
      allow read: if true;
      allow write: if isAdmin(); // Solo los admins pueden crear, actualizar o borrar productos.
    }
    
    // Reglas para la colección 'admins'.
    match /admins/{adminId} {
        // Solo un admin puede leer su propio documento. Nadie puede escribir aquí desde el cliente.
        allow read: if isAdmin() && request.auth.uid == adminId;
        allow write: if false; // La colección de admins se gestiona desde la consola de Firebase.
    }

    // Reglas para la colección de consejos de la comunidad
    match /community-tips/{tipId} {
      allow read: if resource.data.isApproved == true || isAdmin();
      allow create: if true; // Cualquiera puede enviar un consejo para moderación
      
      // La actualización se permite si un usuario está logueado (para añadir respuestas)
      // O si es un admin (para borrar respuestas, que es una actualización del array).
      allow update: if request.auth != null || isAdmin();
      
      // Se elimina el permiso de borrado para los consejos principales.
      allow delete: if false; 
    }
  }
}
