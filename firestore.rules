rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Reglas para la colección 'catalog'
    // Cualquiera puede leer el catálogo (necesario para la tienda).
    // Nadie puede escribir directamente desde el cliente (solo desde el panel de admin).
    match /catalog/{categoryId} {
      allow read: if true;
      allow write: if false;
    }

    // Reglas para la colección 'community-tips'
    // - Cualquiera puede leer los consejos aprobados.
    // - Cualquiera puede crear un nuevo consejo (la moderación se hace con la IA).
    // - SOLO los administradores pueden actualizar o eliminar consejos y sus respuestas.
    match /community-tips/{tipId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if request.auth != null && request.auth.token.email in get(/databases/$(database)/documents/configuration/admin).data.emails;
    }

    // Regla de solo lectura para el documento de configuración de administradores.
    match /configuration/admin {
        allow read: if true;
        allow write: if false;
    }
  }
}
