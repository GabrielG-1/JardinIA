rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Admin: autenticado + email verificado en la lista
    // La lista se define dentro de la función para evitar
    // problemas de scope en evaluaciones anidadas de reglas.
    function isAdmin() {
      return request.auth != null
          && request.auth.token.email != null
          && request.auth.token.email.lower() in [
               'programaciongabriel2025@gmail.com'
             ];
    }

    // ------------------------------------------------------------------
    // /catalog/{categoryId}
    // Lectura pública. Solo admin puede crear, editar o eliminar.
    // ------------------------------------------------------------------
    match /catalog/{categoryId} {
      allow read:                 if true;
      allow create, update, delete: if isAdmin();
    }

    // ------------------------------------------------------------------
    // /community-tips/{tipId}
    // Lectura pública solo de tips aprobados (admin ve todos).
    // Cualquiera puede crear (van a moderación).
    // Solo admin puede editar o eliminar.
    // ------------------------------------------------------------------
    match /community-tips/{tipId} {
      allow read:   if (resource != null && resource.data.isApproved == true)
                    || isAdmin();
      allow create: if true;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ------------------------------------------------------------------
    // /site-settings/{docId}
    // Logo y configuración global del sitio. Lectura pública.
    // ------------------------------------------------------------------
    match /site-settings/{docId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ------------------------------------------------------------------
    // /settings/{docId}   (incluye /settings/hero)
    // Configuración de secciones del sitio. Lectura pública.
    // ------------------------------------------------------------------
    match /settings/{docId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ------------------------------------------------------------------
    // Denegar cualquier otra colección no declarada explícitamente.
    // Protege contra colecciones futuras que queden sin reglas.
    // ------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
