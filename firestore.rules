rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Función para verificar si el usuario autenticado es un administrador.
    // Los correos deben estar en minúsculas en la lista.
    function isAdmin() {
      // REEMPLAZA ESTO CON TUS CORREOS REALES EN MINÚSCULAS
      let adminEmails = ['admin1@example.com', 'admin2@example.com']; 
      return request.auth != null && request.auth.token.email.lower() in adminEmails;
    }

    // Reglas para la colección 'catalog'
    match /catalog/{categoryId} {
      // Cualquiera puede leer el catálogo de productos.
      allow read: if true;
      
      // Solo los administradores pueden crear, actualizar o eliminar categorías/productos.
      allow write: if isAdmin();
    }
    
    // Reglas para la colección 'community-tips'
    match /community-tips/{tipId} {
      // Cualquiera puede leer los consejos que han sido aprobados.
      allow read: if resource.data.isApproved == true;
      
      // Cualquiera puede crear un nuevo consejo.
      allow create: if true;
      
      // Los usuarios autenticados pueden actualizar (para añadir respuestas) y los admins también.
      allow update: if request.auth != null || isAdmin();
      
      // Solo los administradores pueden eliminar un consejo completo.
      allow delete: if isAdmin();
    }
    
    // Reglas para cualquier otra colección (denegar por defecto)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
