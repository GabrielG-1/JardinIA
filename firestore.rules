rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Reglas para la colección 'catalog'
    // Permite la escritura (crear, actualizar, borrar) solo si el usuario
    // tiene el custom claim de 'admin' en su token de autenticación.
    match /catalog/{categoryId} {
      allow read: if true;
      allow write: if request.auth.token.admin == true;
    }
    
    // Reglas para la colección de consejos de la comunidad
    match /community-tips/{tipId} {
      // Leer: Cualquiera puede leer consejos aprobados. Los admins pueden leer todos.
      allow read: if resource.data.isApproved == true || request.auth.token.admin == true;
      
      // Crear: Cualquiera puede enviar un consejo para moderación.
      allow create: if true;
      
      // Actualizar (Añadir respuestas): Solo los admins pueden añadir respuestas.
      allow update: if request.auth.token.admin == true;
      
      // Borrar: Solo los admins pueden borrar el consejo principal o sus respuestas.
      // Esta es la regla clave que se está corrigiendo.
      allow delete: if request.auth.token.admin == true;
    }
  }
}
