
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función para verificar si el usuario tiene el claim de administrador en su token.
    // Este claim se asigna del lado del servidor cuando el usuario inicia sesión.
    function isUserAdmin() {
      return request.auth.token.admin == true;
    }

    // Reglas para la colección 'catalog'
    match /catalog/{categoryId} {
      allow read: if true;
      // Solo los administradores pueden crear, actualizar o borrar (write).
      allow write: if isUserAdmin();
    }
    
    // Reglas para la colección de consejos de la comunidad
    match /community-tips/{tipId} {
      // Todos pueden leer consejos aprobados. Los admins pueden leer todo.
      allow read: if resource.data.isApproved == true || isUserAdmin();
      // Cualquiera puede enviar un consejo para moderación.
      allow create: if true;
      // Los usuarios autenticados pueden añadir respuestas (actualizar el array). Los admins pueden modificar todo.
      allow update: if request.auth != null || isUserAdmin();
      // Solo los administradores pueden borrar el consejo principal.
      allow delete: if isUserAdmin();
    }
  }
}
