rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Reglas para la colección 'catalog'
    // Permite a cualquiera leer, pero solo los administradores pueden escribir, actualizar o eliminar.
    match /catalog/{categoryId} {
      allow read: if true;
      allow write: if request.auth.token.admin == true;
    }
    
    // Reglas para la colección de consejos de la comunidad
    match /community-tips/{tipId} {
      // Cualquiera puede leer consejos aprobados, los admins pueden leer todos.
      allow read: if resource.data.isApproved == true || request.auth.token.admin == true;
      // Cualquiera puede enviar un consejo para moderación.
      allow create: if true;
      // Admins pueden modificar. Usuarios autenticados pueden añadir respuestas.
      allow update: if request.auth.token.admin == true || request.auth != null;
      // Los administradores solo pueden borrar el consejo principal si NO tiene respuestas.
      allow delete: if request.auth.token.admin == true && (resource.data.replies == null || resource.data.replies.size() == 0);
    }
  }
}
