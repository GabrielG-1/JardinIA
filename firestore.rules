rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // === Rol de admin por documento ===
    // Debe existir /admins/<UID> para cada admin.
    match /admins/{uid} {
      // cada usuario puede LEER solo su propio doc (útil para diagnosticar)
      allow read: if request.auth != null && request.auth.uid == uid;
      // no permitir escribir desde el cliente (evita escalar privilegios)
      allow write: if false;
    }

    // helper: verifica rol admin SIN necesidad de lectura
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    // Reglas para la colección 'catalog'
    match /catalog/{categoryId} {
      allow read: if true;
      allow write: if isAdmin(); // Solo los admins pueden crear, actualizar o borrar productos.
    }

    // === community-tips ===
    match /community-tips/{tipId} {
      allow read: if resource.data.isApproved == true || isAdmin();
      allow create: if request.auth != null;
      // (como antes) usuarios logueados pueden editar respuestas en el array
      allow update: if request.auth != null || isAdmin();
      // BORRAR SOLO ADMIN (vía /admins/<uid>)
      allow delete: if isAdmin();
    }
  }
}
