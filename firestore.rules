rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    // Checks if the requesting user's email is in the list of admins.
    function isAdmin() {
      // IMPORTANT: Replace the placeholder emails below with the real emails 
      // of your administrators before deploying your application.
      let adminEmails = ['admin1@example.com', 'admin2@example.com'];
      return request.auth != null && request.auth.token.email in adminEmails;
    }

    // --- Catalog Rules ---
    // Anyone can read the catalog.
    // Only admins can modify (create, update, delete) the catalog.
    match /catalog/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Community Tips Rules ---
    match /community-tips/{tipId} {
      // Anyone can read tips that are approved.
      allow read: if resource.data.isApproved == true;

      // Anyone can submit a new tip.
      allow create: if true;
      
      // Anyone authenticated can update a tip (to add replies).
      // Admins can also update (to remove replies).
      allow update: if request.auth != null;

      // Only admins can delete a whole tip.
      allow delete: if isAdmin();
    }
  }
}
