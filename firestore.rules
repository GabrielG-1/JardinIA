rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the requesting user is an admin.
    // It checks for the existence of a document with the user's UID in the /admins collection.
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Rules for the 'admins' collection itself.
    // Only other admins can read this collection. No one can write to it from the client.
    match /admins/{uid} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Rules for the 'catalog' collection.
    // Anyone can read, but only admins can write (create, update, delete).
    match /catalog/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Rules for the 'community-tips' collection.
    match /community-tips/{tipId} {
      // Anyone can read a tip if it is approved. Admins can read all tips.
      allow read: if resource.data.isApproved == true || isAdmin();
      
      // Any authenticated user can create a tip (it will be submitted for moderation).
      allow create: if request.auth != null;
      
      // Any authenticated user can add a reply. Admins can modify the whole document.
      allow update: if request.auth != null || isAdmin();
      
      // Only admins can delete a tip or a reply within it.
      allow delete: if isAdmin();
    }
  }
}
