
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Reglas para la colección 'catalog'
    // PERMITE: que cualquiera lea los productos.
    // BLOQUEA: que los clientes modifiquen o borren productos directamente.
    // La escritura solo debe ser posible a través de lógica de servidor segura (panel de admin).
    match /catalog/{categoryId} {
      allow read: if true;
      allow write: if false; // Protege el catálogo contra modificaciones no autorizadas desde el cliente.
    }

    // Reglas para la colección 'community-tips'
    // PERMITE: que cualquiera lea y cree nuevos consejos.
    // PERMITE: que usuarios autenticados (como el admin) actualicen o eliminen consejos.
    match /community-tips/{tipId} {
      allow read, create: if true;
      allow update, delete: if request.auth != null; // Solo usuarios con sesión iniciada pueden modificar o borrar.
    }
  }
}
