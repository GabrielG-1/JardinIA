rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow public read access to the product catalog
    match /catalog/{categoryId} {
      allow read: if true;
      allow write: if false; // Disallow client-side writes
    }
    
    // Allow anyone to read approved community tips and create new ones.
    // Updates and deletions are more restricted.
    match /community-tips/{tipId} {
      allow read, create: if true;
      allow update, delete: if request.auth != null;
    }

    // Default deny all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
