rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Read-only access to the catalog for all users.
    // Writes should only be done via the admin panel (server-side).
    match /catalog/{categoryId} {
      allow read: if true;
      allow write: if false; // Disallow client-side writes completely
    }

    // Community tips can be read by anyone.
    // New tips can be created by anyone.
    // Updates (like adding a reply) require authentication.
    // Deletion is NOT allowed from the client. It must go through the secure server action.
    match /community-tips/{tipId} {
      allow read, create: if true;
      allow update: if request.auth != null;
      allow delete: if false; // Explicitly deny client-side deletion
    }
  }
}
