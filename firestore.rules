rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /catalog/{categoryId} {
      allow read: if true;
      // Write access should be restricted. 
      // It's managed by server-side logic (e.g., Admin SDK) or secured functions.
      allow write: if false; 
    }

    match /community-tips/{tipId} {
      allow read, create: if true;
      
      // Allow updates (like adding replies) and deletes only if the user is authenticated.
      // The application's UI is responsible for showing the delete button ONLY to admins,
      // providing the primary layer of authorization control. This rule serves as a
      // backend safeguard ensuring no anonymous user can perform these actions.
      allow update, delete: if request.auth != null;
    }
  }
}
