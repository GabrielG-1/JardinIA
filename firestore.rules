rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Reglas para la colección 'catalog'
    match /catalog/{categoryId} {
      allow read: if true;
      // Solo los administradores (con el claim 'admin') pueden escribir.
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
    
    // Reglas para la colección de consejos de la comunidad
    match /community-tips/{tipId} {
      allow read: if resource.data.isApproved == true || (request.auth != null && request.auth.token.admin == true);
      allow create: if true; // Cualquiera puede enviar un consejo para moderación
      // Los usuarios logueados pueden añadir respuestas. Los administradores pueden modificar.
      allow update: if request.auth != null; 
      // Solo los administradores (con el claim 'admin') pueden borrar.
      allow delete: if request.auth != null && request.auth.token.admin == true; 
    }
  }
}
