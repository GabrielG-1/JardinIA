rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the requesting user is an admin.
    // IMPORTANT: Replace the placeholder emails below with your actual admin emails before deploying.
    function isAdmin() {
      let adminEmails = ['admin1@example.com', 'admin2@example.com'];
      return request.auth != null && request.auth.token.email in adminEmails;
    }

    // Rules for the 'catalog' collection.
    // Anyone can read the catalog, but only authenticated admins can write to it.
    match /catalog/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Rules for the 'community-tips' collection.
    match /community-tips/{tipId} {
      // ANYONE can READ tips that have been approved by the AI.
      allow read: if resource.data.isApproved == true;

      // ANYONE can CREATE a new tip. The isApproved field will be set by the backend.
      allow create: if true;
      
      // An AUTHENTICATED user can UPDATE a tip (e.g., to add a reply).
      // An ADMIN can also UPDATE a tip (e.g., to remove a reply).
      allow update: if request.auth != null;

      // ONLY an ADMIN can DELETE a tip.
      allow delete: if isAdmin();
    }

  }
}
