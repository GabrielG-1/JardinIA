rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email.lower() in ['programaciongabriel2025@gmail.com'];
    }

    // Carpeta del logo
    match /site-settings/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Imágenes de productos
    match /product-images/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
