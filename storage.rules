
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Helper function to check for admin role
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email.lower() in ['programaciongabriel2025@gmail.com'];
    }

    // Site settings like the logo are public-read
    match /site-settings/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Product images are public-read
    match /product-images/{allPaths=**} {
      allow read: if true;
      // Allow write only for authenticated admins
      // and enforce image content types and a reasonable size limit (e.g., 5MB)
      allow write: if isAdmin()
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
