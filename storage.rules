rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isAdminEmail() {
      return request.auth != null
             && request.auth.token.email != null
             && request.auth.token.email.lower() in [
               "programaciongabriel2025@gmail.com"
             ];
    }

    // Carpeta del logo del sitio
    match /site-settings/{allPaths=**} {
      allow read: if true;          // público (para mostrar el logo)
      allow write: if isAdminEmail(); // subir/actualizar solo admin
    }

    // imágenes de los productos
    match /product-images/{allPaths=**} {
      allow read: if true;
      allow write: if isAdminEmail();
    }
  }
}
