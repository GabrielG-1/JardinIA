
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isAdminEmail() {
      // Importante: La lista de correos debe coincidir con firestore.rules
      return request.auth != null
             && request.auth.token.email != null
             && request.auth.token.email.lower() in [
               'programaciongabriel2025@gmail.com'
             ];
    }

    // Logo del sitio: cualquiera puede leerlo, solo admin puede escribirlo.
    match /site-settings/logo {
      allow read: if true;
      allow write: if isAdminEmail();
    }

    // Imágenes de productos: cualquiera puede leerlas, solo admin puede escribirlas.
    match /product-images/{allPaths=**} {
      allow read: if true;
      allow write: if isAdminEmail();
    }
  }
}
