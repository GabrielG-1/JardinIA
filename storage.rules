rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isAdminEmail() {
      return request.auth != null
             && request.auth.token.email != null
             && request.auth.token.email.lower() in [
               'programaciongabriel2025@gmail.com'
             ];
    }

    // El logo del sitio es público para leer, pero solo los administradores pueden cambiarlo.
    match /site-settings/logo {
      allow read: if true;
      allow write: if isAdminEmail();
    }

    // Las imágenes de productos son públicas para leer. Solo los administradores pueden subirlas.
    match /product-images/{allPaths=**} {
      allow read: if true;
      allow write: if isAdminEmail();
    }
  }
}
