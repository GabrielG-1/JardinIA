
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email.lower() in ['programaciongabriel2025@gmail.com'];
    }

    // Reglas más específicas y seguras
    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function isNotTooLarge() {
      // Limita la subida a 5MB
      return request.resource.size < 5 * 1024 * 1024;
    }

    // Carpeta del logo (site-settings)
    match /site-settings/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() && isImage() && isNotTooLarge();
    }

    // Imágenes de productos (product-images)
    match /product-images/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() && isImage() && isNotTooLarge();
    }
  }
}
