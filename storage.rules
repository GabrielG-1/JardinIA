rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Admin: usuario autenticado con email autorizado
    function isAdmin() {
      return request.auth != null
          && request.auth.token.email != null
          && request.auth.token.email.lower() in ['programaciongabriel2025@gmail.com'];
    }

    // Validación de archivo: máx 5MB, solo imágenes
    // Solo se evalúa en create/update (request.resource es null en delete)
    function isValidImage() {
      return request.resource.size < 5 * 1024 * 1024
          && request.resource.contentType.matches('image/.*');
    }

    // Logo y configuración global del sitio
    match /site-settings/{allPaths=**} {
      allow read:          if true;
      allow create, update: if isAdmin() && isValidImage();
      allow delete:         if isAdmin();
    }

    // Imágenes de productos del catálogo
    match /product-images/{allPaths=**} {
      allow read:          if true;
      allow create, update: if isAdmin() && isValidImage();
      allow delete:         if isAdmin();
    }

    // Imágenes del hero / banner principal
    match /hero-images/{allPaths=**} {
      allow read:          if true;
      allow create, update: if isAdmin() && isValidImage();
      allow delete:         if isAdmin();
    }

    // Denegar acceso a cualquier otra ruta no declarada
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
